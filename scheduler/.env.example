# 环境配置
ENVIRONMENT=development

# 日志配置
LOG_LEVEL=INFO

# SQL 日志开关：true=打印每条执行的完整 SQL（默认，便于开发/Docker 排查）；
# 高并发生产环境如需降低开销可设为 false
SQL_ECHO=true

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xianyu_auto_reply

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Scheduler服务配置
SCHEDULER_PORT=8091

# 任务配置（秒）
REDELIVERY_INTERVAL=5
RATE_INTERVAL=20

# 服务间通信URL
WEBSOCKET_SERVICE_URL=http://localhost:8090
BACKEND_WEB_SERVICE_URL=http://localhost:8089

# 静态文件目录（共享，只读）
STATIC_DIR=static
