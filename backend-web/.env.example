# 环境配置
ENVIRONMENT=development

# 日志配置
LOG_LEVEL=INFO

# SQL 日志开关：true=打印每条执行的完整 SQL（默认，便于开发/Docker 排查）；
# 高并发生产环境如需降低开销可设为 false
SQL_ECHO=true

# IM Token 缓存（xy_token_cache 表）随机过期时间区间（小时），不配置默认 5~10 小时
# TOKEN_CACHE_TTL_MIN_HOURS=5
# TOKEN_CACHE_TTL_MAX_HOURS=10

# 监听地址：:: 同时监听 IPv4 和 IPv6（dual-stack），0.0.0.0 仅监听 IPv4
# HOST=::

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xianyu_auto_reply

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Backend-Web服务配置
BACKEND_WEB_PORT=8089

# JWT配置
# 说明：JWT_SECRET_KEY 由数据库统一托管（首次启动自动生成并持久化到 xy_system_settings），无需在此配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS配置（* 表示允许所有来源，生产环境建议指定具体域名）
CORS_ORIGINS=*

# 服务间通信URL
WEBSOCKET_SERVICE_URL=http://localhost:8090
SCHEDULER_SERVICE_URL=http://localhost:8091

# 分销卡券上游服务基址（「分销卡券」页面通过该上游卡券系统提货）
CARD_DOCK_BASE_URL=http://backend.zhinianboke.com

# 外部 API 密钥管理服务（个人设置「对接卡密秘钥」一键创建密钥）
# 基址复用 CARD_DOCK_BASE_URL，仅需配置创建密钥的鉴权 key（禁止写死）
EXTERNAL_API_KEY=zhinian_bk

# 远程官方服务基址（仪表盘广告、系统公告等 = 本地内容 + 远程官方内容，与桌面版同源）
REMOTE_OFFICIAL_BASE_URL=https://xy.zhinianboke.com
# 是否启用远程官方广告合并展示（官方服务器自身部署时建议设为 false，避免重复展示自己的广告）
ENABLE_REMOTE_ADS=true
# 是否启用远程官方公告合并展示（官方服务器自身部署时建议设为 false，避免重复展示自己的公告）
ENABLE_REMOTE_ANNOUNCEMENTS=true
# 是否启用远程官方弹窗公告合并展示（官方服务器自身部署时建议设为 false，避免重复展示自己的弹窗公告）
ENABLE_REMOTE_POPUP_ANNOUNCEMENTS=true

# 静态文件目录（共享）
STATIC_DIR=static

# 数据库备份文件目录（与 scheduler 共享，scheduler 写入、backend-web 读取下载）
BACKUP_DIR=backups

# 前端公网访问地址（用于生成前端页面分享链接）
FRONTEND_PUBLIC_URL=http://localhost:9000

# Backend-Web服务的公网访问地址（用于生成文件URL）
BACKEND_WEB_PUBLIC_URL=http://localhost:8089
AUTO_START_CRAWL_JOBS=false

# 数据库连接池配置（账号数量较大时可调优；不配置则使用代码内置默认值）
# 重要：DB_POOL_SIZE + DB_MAX_OVERFLOW 不应超过 MySQL 的 max_connections，
# 否则连接池打满后会触发 MySQL 的 "Too many connections"。
DB_POOL_SIZE=40          # 常驻连接数（API 服务）
DB_MAX_OVERFLOW=60       # 溢出连接数（峰值 = DB_POOL_SIZE + DB_MAX_OVERFLOW = 100）
DB_POOL_TIMEOUT=30       # 从连接池获取连接的最长等待秒数
DB_POOL_RECYCLE=1800     # 连接回收时间（秒），防止 MySQL 断开陈旧连接
DB_POOL_PRE_PING=true    # 取连接前 ping，自动剔除失效连接
DB_POOL_USE_LIFO=true    # LIFO 复用最近连接，便于空闲连接被回收
DB_CONNECT_TIMEOUT=10    # 建立 TCP 连接的超时秒数，远程库不可达时快速失败
