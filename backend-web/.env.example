# 环境配置
ENVIRONMENT=development

# 日志配置
LOG_LEVEL=INFO

# SQL 日志开关：true=打印每条执行的完整 SQL（默认，便于开发/Docker 排查）；
# 高并发生产环境如需降低开销可设为 false
SQL_ECHO=true

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xianyu_auto_reply

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Backend-Web服务配置
BACKEND_WEB_PORT=8089

# JWT配置
# 说明：JWT_SECRET_KEY 由数据库统一托管（首次启动自动生成并持久化到 xy_system_settings），无需在此配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# CORS配置（* 表示允许所有来源，生产环境建议指定具体域名）
CORS_ORIGINS=*

# 服务间通信URL
WEBSOCKET_SERVICE_URL=http://localhost:8090
SCHEDULER_SERVICE_URL=http://localhost:8091

# 静态文件目录（共享）
STATIC_DIR=static

# 数据库备份文件目录（与 scheduler 共享，scheduler 写入、backend-web 读取下载）
BACKUP_DIR=backups

# 前端公网访问地址（用于生成前端页面分享链接）
FRONTEND_PUBLIC_URL=http://localhost:9000

# Backend-Web服务的公网访问地址（用于生成文件URL）
BACKEND_WEB_PUBLIC_URL=http://localhost:8089
AUTO_START_CRAWL_JOBS=false