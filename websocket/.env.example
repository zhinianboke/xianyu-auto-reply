# 环境配置
ENVIRONMENT=development

# 日志配置
LOG_LEVEL=INFO

# SQL 日志开关：true=打印每条执行的完整 SQL（默认，便于开发/Docker 排查）；
# 高并发生产环境如需降低开销可设为 false
SQL_ECHO=true

# 数据库配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=xianyu_auto_reply

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# WebSocket服务配置
WEBSOCKET_PORT=8090

# 浏览器配置
MAX_CAPTCHA_CONCURRENT=1
BROWSER_HEADLESS=true

# DrissionPage 滑块兜底引擎（Playwright 主引擎失败后再试一次）
CAPTCHA_DRISSIONPAGE_FALLBACK_ENABLED=true
CAPTCHA_DRISSIONPAGE_TIMEOUT=25
CAPTCHA_DRISSIONPAGE_HEADLESS=true

# Token刷新配置（秒）
TOKEN_REFRESH_INTERVAL=72000
TOKEN_RETRY_INTERVAL=7200

# 服务间通信URL
BACKEND_WEB_SERVICE_URL=http://localhost:8089

# 静态文件目录（共享）
STATIC_DIR=static

# 数据库连接池配置（账号数量较大时可调优；不配置则使用代码内置默认值）
# 重要：DB_POOL_SIZE + DB_MAX_OVERFLOW 不应超过 MySQL 的 max_connections，
# 否则连接池打满后会触发 MySQL 的 "Too many connections"。
DB_POOL_SIZE=100         # 常驻连接数（本服务运行账号任务，连接需求最大）
DB_MAX_OVERFLOW=150      # 溢出连接数（峰值 = DB_POOL_SIZE + DB_MAX_OVERFLOW = 250）
DB_POOL_TIMEOUT=30       # 从连接池获取连接的最长等待秒数
DB_POOL_RECYCLE=1800     # 连接回收时间（秒），防止 MySQL 断开陈旧连接
DB_POOL_PRE_PING=true    # 取连接前 ping，自动剔除失效连接
DB_POOL_USE_LIFO=true    # LIFO 复用最近连接，便于空闲连接被回收
DB_CONNECT_TIMEOUT=10    # 建立 TCP 连接的超时秒数，远程库不可达时快速失败
