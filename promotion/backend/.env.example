# ========================================
# 推广返佣系统 - 环境变量配置示例
# 复制此文件为 .env 并修改对应值
# ========================================

# ---------- 环境 ----------
ENVIRONMENT=development
LOG_LEVEL=INFO

# ---------- 服务端口 ----------
PROMOTION_PORT=8092

# ---------- 数据库（MySQL） ----------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=xianyu_data

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------- JWT ----------
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ---------- CORS ----------
# 多个源用逗号分隔，或设为 * 允许所有
CORS_ORIGINS=*

# ---------- 静态文件 ----------
STATIC_DIR=static

# 数据库连接池配置（账号数量较大时可调优；不配置则使用代码内置默认值）
# 重要：DB_POOL_SIZE + DB_MAX_OVERFLOW 不应超过 MySQL 的 max_connections，
# 否则连接池打满后会触发 MySQL 的 "Too many connections"。
DB_POOL_SIZE=10          # 常驻连接数（推广服务，按需启用）
DB_MAX_OVERFLOW=20       # 溢出连接数（峰值 = DB_POOL_SIZE + DB_MAX_OVERFLOW = 30）
DB_POOL_TIMEOUT=30       # 从连接池获取连接的最长等待秒数
DB_POOL_RECYCLE=1800     # 连接回收时间（秒），防止 MySQL 断开陈旧连接
DB_POOL_PRE_PING=true    # 取连接前 ping，自动剔除失效连接
DB_POOL_USE_LIFO=true    # LIFO 复用最近连接，便于空闲连接被回收
DB_CONNECT_TIMEOUT=10    # 建立 TCP 连接的超时秒数，远程库不可达时快速失败
