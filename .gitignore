# ==========================================
# 闲鱼自动回复系统 - Git忽略配置
# ==========================================

# ------------------------------------------
# 环境变量文件（包含敏感信息）
# ------------------------------------------
**/.env
**/.env.local
**/.env.*.local
.env.enc
!**/.env.example

# ------------------------------------------
# Python相关
# ------------------------------------------
# 虚拟环境
**/venv/
**/.venv/
**/env/
**/ENV/

# 字节码缓存
**/__pycache__/
*.py[cod]
*$py.class

# 打包/分发产物
**/*.egg-info/
*.egg
*.whl
dist/
eggs/
.eggs/
.installed.cfg

# 编译产物（Cython / C扩展）
*.so
*.pyd
*.pyo
*.pyc
.Python
pip-log.txt
pip-delete-this-directory.txt

# 测试覆盖率
.coverage
.coverage.*
.pytest_cache/
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# 类型检查
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb

# ------------------------------------------
# Node.js / 前端相关
# ------------------------------------------
**/node_modules/
/frontend/dist/
/frontend/build/
/promotion/frontend/dist/
/promotion/frontend/build/
.npm/
.pnpm-store/
.yarn/
.pnp.*

# 缓存
.cache/
.eslintcache
*.tsbuildinfo
.vite/
.turbo/

# ------------------------------------------
# IDE / 编辑器
# ------------------------------------------
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ------------------------------------------
# AI IDE 配置文件
# ------------------------------------------
.kiro/
.claude/
CLAUDE.md
.windsurf/

# ------------------------------------------
# 操作系统
# ------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ------------------------------------------
# 日志文件
# ------------------------------------------
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------
# 数据库文件
# ------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal

# ------------------------------------------
# 浏览器自动化数据
# ------------------------------------------
**/browser_data/
**/playwright-data/
**/chromium_data/
.playwright/
ms-playwright/

# ------------------------------------------
# 上传文件目录
# ------------------------------------------
**/uploads/
**/static/uploads/
!**/static/uploads/.gitkeep

# ------------------------------------------
# 临时文件与备份文件
# ------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.old
*_backup
*_old

# ------------------------------------------
# Docker相关（本地卷数据）
# ------------------------------------------
docker/data/
docker/volumes/
docker/mysql/
docker/redis/
xianyu_auto_reply/

# ------------------------------------------
# 证书和密钥
# ------------------------------------------
*.pem
*.key
*.crt
*.p12
*.pfx
!*.example.pem

# ------------------------------------------
# 测试文件
# ------------------------------------------
test/
!test/.gitkeep

# ------------------------------------------
# 静态资源（根目录）
# ------------------------------------------
/static/uploads/
!static/uploads/.gitkeep

# ------------------------------------------
# 编译打包输出
# ------------------------------------------
/build_output/
/release/
/data/
*.build/
*.dist/
*.onefile-build/

# ------------------------------------------
# 离线依赖包目录
# ------------------------------------------
/offline_packages/

# ------------------------------------------
# 许可与连接数据文件
# ------------------------------------------
license.dat
connection.dat
*.dat

# ------------------------------------------
# 网络抓包文件
# ------------------------------------------
*.har

# ------------------------------------------
# 阿里云相关
# ------------------------------------------
/aliyun-140/
aliyun-140.zip

# ------------------------------------------
# 文档生成
# ------------------------------------------
docs/_build/
site/

# ------------------------------------------
# 其他
# ------------------------------------------
.sass-cache/
*.css.map
*.sass.map
*.scss.map

# ------------------------------------------
# 用户密码重置脚本（含敏感操作，不纳入版本管理）
# ------------------------------------------
reset_user_password.sh
